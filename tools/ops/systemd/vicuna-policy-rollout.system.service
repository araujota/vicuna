[Unit]
Description=Vicuña Policy Live Rollout Controller
After=network-online.target vicuna-runtime.service vicuna-policy-registry.service
Wants=network-online.target vicuna-runtime.service vicuna-policy-registry.service

[Service]
Type=oneshot
User=@VICUNA_SERVICE_USER@
Group=@VICUNA_SERVICE_GROUP@
WorkingDirectory=@VICUNA_REPO_ROOT@
EnvironmentFile=-@VICUNA_ENV_FILE@
ExecStart=@VICUNA_REPO_ROOT@/tools/ops/run-with-service-logs.sh policy-rollout @VICUNA_REPO_ROOT@/tools/ops/run-policy-rollout.sh
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
