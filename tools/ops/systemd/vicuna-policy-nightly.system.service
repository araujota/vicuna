[Unit]
Description=Vicuña Policy Nightly Offline Batch
After=network-online.target vicuna-runtime.service
Wants=network-online.target vicuna-runtime.service

[Service]
Type=oneshot
User=@VICUNA_SERVICE_USER@
Group=@VICUNA_SERVICE_GROUP@
WorkingDirectory=@VICUNA_REPO_ROOT@
EnvironmentFile=-@VICUNA_ENV_FILE@
ExecStart=@VICUNA_REPO_ROOT@/tools/ops/run-with-service-logs.sh policy-nightly @VICUNA_REPO_ROOT@/tools/ops/run-policy-nightly.sh
TimeoutStartSec=1800

[Install]
WantedBy=multi-user.target
