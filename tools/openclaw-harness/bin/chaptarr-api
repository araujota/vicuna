#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH='' cd -- "$SCRIPT_DIR/../../.." && pwd)"

exec node "$REPO_ROOT/tools/openclaw-harness/dist/chaptarr.js" \
  --secrets-path="$REPO_ROOT/.cache/vicuna/openclaw-tool-secrets.json" \
  "$@"
